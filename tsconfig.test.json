{
  "//": "Compiles unit tests (and only their sources) to out-test/ so the built-in node:test runner can execute them. Kept separate from the main build (tsconfig.json), which excludes *.test.ts so test code never ships in dist/.",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "out-test"
  },
  "include": [
    "src/methodology/specChange.ts",
    "src/methodology/specChange.test.ts",
    "src/methodology/qualityGates.ts",
    "src/methodology/qualityGates.test.ts",
    "src/views/kanban/host/storage/sliceBoard.ts",
    "src/views/kanban/host/storage/sliceBoard.test.ts",
    "src/store/frontmatter.ts",
    "src/store/frontmatter.test.ts",
    "src/store/ids.ts",
    "src/store/ids.test.ts",
    "src/services/WorktreeService.ts",
    "src/services/WorktreeService.test.ts",
    "src/services/agentTeams/tmuxDispatcher.ts",
    "src/services/agentTeams/tmuxDispatcher.test.ts",
    "src/services/agentTeams/tmuxShimInstall.ts",
    "src/services/agentTeams/tmuxShimInstall.test.ts",
    "src/services/agentTeams/ipcServer.ts",
    "src/services/agentTeams/ipcRoundtrip.test.ts",
    "src/services/agentTeams/tmuxSurface.ts",
    "src/services/agentTeams/conformance.test.ts",
    "src/github/specMerge.ts",
    "src/github/specMerge.test.ts",
    "src/mcp/boardDetection.ts",
    "src/mcp/boardDetection.test.ts"
  ],
  "exclude": ["node_modules"]
}
