# Match a node_modules directory AND a symlink (no trailing slash): a worktree's
# shared-deps symlink is a symlink, which `node_modules/` would NOT ignore — so it
# leaked into `git add -A` and was committed as a self-referential loop (TEP-th3i18 #16).
node_modules
dist/
*.vsix
.vscode-test/
*.log
# Built webview bundle (regenerated by npm run compile:webview)
media/kanban/
# Unit-test compile output (tsconfig.test.json)
out-test/
# Built Antora docs site (regenerated by npm run docs:build)
docs/build/
# Subagent git worktrees
.claude/worktrees/

# Per-machine MCP config — generated by the extension, never committed
.mcp.json
