    "mcpServerDefinitionProviders": [
      {
        "id": "thinkube.kanban",
        "label": "Thinkube Kanban"
      }
    ],
    "configuration": {
      "title": "Thinkube Kanban",
      "properties": {
        "thinkube.kanban.allowAIWrites": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Thinkube Kanban MCP server's mutating tools (move_slice, update_slice, write_decision, …). Set to false for navigator mode — AI can read and propose but cannot write. Overridden to false by `thinkube.kanban.mode = navigator`."
        },
        "thinkube.kanban.mode": {
          "type": "string",
          "enum": [
            "navigator",
            "driver",
            "both"
          ],
          "default": "both",
          "description": "Pair-programming role assignment. `navigator`: AI reads and proposes only (writes are blocked). `driver`: AI can write (typical when AI is leading implementation). `both`: either party can write at will (default)."
        },
        "thinkube.kanban.docsGateMode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ],
          "default": "advisory",
          "description": "→ Done documentation gate (TEP-tgh6iy). A slice marked `docs: required` must have its docs updated (pass `docs_done`) before reaching Done. `advisory` (default): the move is allowed but returns a warning — for rolling the gate out. `blocking`: an unsatisfied docs obligation refuses the move."
        },
        "thinkube.worktree.baseDir": {
          "type": "string",
          "default": "",
          "description": "Base directory for per-Spec git worktrees created by \"Start Spec in Worktree\". Empty = a sibling `<repo>-worktrees/` directory next to the repo. Keep it outside the repo tree so board discovery doesn't list worktrees as nested boards."
        },
        "thinkube.boards.root": {
          "type": "string",
          "default": "",
          "description": "Central board root (ADR-0008 / SP-8): the directory holding every Thinking Space's board, namespaced by `<container>/<rel>` (e.g. `Platform/extensions/thinkube-ai-integration`). Empty = legacy co-located `.thinkube/` in each repo. In thinkube this is the cloned sidecar board repo at `/home/thinkube/<board-repo>`."
        },
        "thinkube.boards.showWorktrees": {
          "type": "boolean",
          "default": false,
          "description": "Show linked git worktrees (created by \"Start Spec in Worktree\") as their own entries in the Thinking Spaces navigator. A worktree shares its canonical repo's board — it is not a separate board — so it is hidden by default to keep the navigator a list of logical Thinking Spaces. Turn on to use the entry as a re-entry point into the isolated worktree checkout."
        },
        "thinkube.orchestrator.maxConcurrent": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Maximum concurrent `claude -p` workers per Spec when \"Orchestrate Next Slice\" dispatches the ready frontier (SP-tgs8nz). A wider footprint-disjoint frontier queues and drains as slots free."
        },
        "thinkube.agentTeams.enableExperimental": {
          "type": "boolean",
          "default": false,
          "description": "Enable Claude Code's experimental agent teams in VS Code (SP-tgnb5o). When on, the extension exports `CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1` + a synthetic `$TMUX` to Claude sessions/terminals and installs a fake-`tmux` shim on PATH so teammates render as native VS Code terminal panes. Off by default: it shadows `tmux` on the terminal PATH and sets `$TMUX`, so opt in deliberately. Takes effect for sessions/terminals started after a window reload."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node scripts/build-assets.mjs && npm run bundle:mcp && npm run compile:webview",
    "bundle:mcp": "node esbuild.mcp.mjs",
    "compile:webview": "npm --prefix webview/kanban run build",
    "install:webview": "npm --prefix webview/kanban install",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "tsc -p tsconfig.test.json && node --test out-test/",
    "test:vscode": "node ./dist/test/runTest.js",
    "publish:ovsx": "ovsx publish",
    "prepublish:ovsx": "npm run compile && npm run package"
  },
