    "configuration": {
      "title": "Thinkube Kanban",
      "properties": {
        "thinkube.kanban.allowAIWrites": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Thinkube Kanban MCP server's mutating tools (move_slice, update_slice, write_decision, …). Set to false for navigator mode — AI can read and propose but cannot write. Overridden to false by `thinkube.kanban.mode = navigator`."
        },
        "thinkube.kanban.mode": {
          "type": "string",
          "enum": [
            "navigator",
            "driver",
            "both"
          ],
          "default": "both",
          "description": "Pair-programming role assignment. `navigator`: AI reads and proposes only (writes are blocked). `driver`: AI can write (typical when AI is leading implementation). `both`: either party can write at will (default)."
        },
        "thinkube.kanban.docsGateMode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ],
          "default": "blocking",
          "description": "→ Done documentation gate (TEP-tgh6iy). A slice marked `docs: required` must have its docs updated (pass `docs_done`) before reaching Done. `blocking` (default — fail closed): an unsatisfied docs obligation refuses the move. `advisory`: the move is allowed but returns a warning (the rollout mode; every TEP-21/SP-1 slice reached Done undocumented under it)."
        },
        "thinkube.worktree.baseDir": {
          "type": "string",
          "default": "",
          "description": "Base directory for per-Spec git worktrees created by \"Start Spec in Worktree\". Empty = a sibling `<repo>-worktrees/` directory next to the repo. Keep it outside the repo tree so thinking space discovery doesn't list worktrees as nested thinkingSpaces."
        },
        "thinkube.thinkingSpace.root": {
          "type": "string",
          "default": "",
          "description": "Central thinking space root (ADR-0008 / SP-8): the directory holding every Thinking Space's thinking space, namespaced by `<container>/<rel>` (e.g. `Platform/extensions/thinkube-ai-integration`). Empty = legacy co-located `.thinkube/` in each repo. In thinkube this is the cloned sidecar thinking space repo at `/home/thinkube/<thinking space-repo>`."
        },
        "thinkube.thinkingSpace.showWorktrees": {
          "type": "boolean",
          "default": false,
          "description": "Show linked git worktrees (created by \"Start Spec in Worktree\") as their own entries in the Thinking Spaces navigator. A worktree shares its canonical repo's thinking space — it is not a separate thinking space — so it is hidden by default to keep the navigator a list of logical Thinking Spaces. Turn on to use the entry as a re-entry point into the isolated worktree checkout."
        },
        "thinkube.orchestrator.maxConcurrent": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Maximum concurrent Agent SDK workers per Spec when \"Orchestrate Spec\" dispatches the ready frontier (SP-tgs8nz). A wider footprint-disjoint frontier queues and drains as slots free."
        },
        "thinkube.orchestrator.verifyCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command run in a slice's worktree to verify it before the orchestrator advances it to Done (green = exit 0), e.g. `ansible-lint` or `npm test`. When empty, the orchestrator runs `npm run compile` if the repo has a package.json, otherwise skips the verify (logged) so a non-JS repo isn't falsely failed by a JS-only gate."
        },
        "thinkube.orchestrator.workerModel": {
          "type": "string",
          "default": "sonnet",
          "description": "The pinned model every orchestrated Agent SDK worker (code/test-author, assessor, judge, acceptance-auditor) runs on (SP-17/1). Passed explicitly as `options.model` on each worker `query()`, so no worker inherits the session/environment model (`ANTHROPIC_MODEL`) — the strong model stays reserved for the pairing session while workers implement on Sonnet. A visible drop in premium-model spend."
        },
        "thinkube.orchestrator.workerModelByRole": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional per-role override map that RAISES an individual worker role (e.g. `judge`, `assessor`) to a stronger model than `thinkube.orchestrator.workerModel` (SP-17/1). A refinement, not a requirement: every role always resolves to the base worker model unless it is listed here."
        },
        "thinkube.orchestrator.promptTemplateDir": {
          "type": "string",
          "default": "",
          "description": "Directory the orchestrator loads its editable prompt-template PROSE from (worker-preamble.md, audit-rules.md, intent-check.md) — doctrine, tweakable without an extension release. Resolution order per template: (1) the orchestrated repo's own `.tandem/prompts/<name>.md` override, (2) this directory when set, (3) the installed tandem-methodology plugin's `templates/` dir (located via `~/.claude/plugins/known_marketplaces.json`), (4) the extension's bundled fallback — so a missing file never breaks a run. The machine-parsed OUTPUT-FORMAT stanzas (JSON reply contracts) are never loaded from templates. Leave empty to use the plugin's doctrine."
        },
        "thinkube.orchestrator.floatLogsToNewWindow": {
          "type": "boolean",
          "default": true,
          "description": "When you open a worker's log (the ≣ on a control-center graph node), pop it directly into its own editor window instead of a beside tab. Falls back to a beside tab where auxiliary windows aren't supported. Turn off to keep logs beside the editor."
        },
        "thinkube.workers.logToOutput": {
          "type": "boolean",
          "default": true,
          "description": "Stream AI worker sessions into the Output panel (scratchpad rounds → 'Thinkube Scratchpad'; orchestration auditors/assessors → 'Thinkube Orchestrator'). On by default during the field-testing phase; turn off to keep the panel quiet."
        },
        "thinkube.agentTeams.enableExperimental": {
          "type": "boolean",
          "default": false,
          "description": "Enable Claude Code's experimental agent teams in VS Code (SP-tgnb5o). When on, the extension exports `CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1` + a synthetic `$TMUX` to Claude sessions/terminals and installs a fake-`tmux` shim on PATH so teammates render as native VS Code terminal panes. Off by default: it shadows `tmux` on the terminal PATH and sets `$TMUX`, so opt in deliberately. Takes effect for sessions/terminals started after a window reload."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "thinkube.thinky",
        "name": "thinky",
        "fullName": "Thinky",
        "description": "Talk to your thinking space — statements, asks, questions, operations",
        "isSticky": true,
        "commands": [
          {
            "name": "readiness",
            "description": "Run the four-dimension readiness check"
          },
          {
            "name": "reframe",
            "description": "Re-synthesize the curated intent from the journal and settled items"
          },
          {
            "name": "contextualize",
            "description": "Refresh the context digest from the declared sources"
          },
          {
            "name": "panic",
            "description": "Wipe derived state, keep the journal (refused after any freeze)"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node scripts/build-assets.mjs && npm run bundle:mcp && npm run compile:webview",
    "bundle:mcp": "node esbuild.mcp.mjs",
    "compile:webview": "npm --prefix webview/kanban run build",
    "install:webview": "npm --prefix webview/kanban install",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "deploy": "scripts/deploy.sh",
    "deploy:release": "scripts/deploy.sh --bump",
    "test": "rm -rf out-test && tsc -p tsconfig.test.json && node --test out-test/",
    "test:vscode": "node ./dist/test/runTest.js",
    "publish:ovsx": "ovsx publish",
    "prepublish:ovsx": "npm run compile && npm run package",
    "docs:build": "node scripts/docs-build.mjs"
  },
