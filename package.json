{
  "name": "thinkube-ai-integration",
  "displayName": "Thinkube AI Integration",
  "description": "Thinkube integration for AI assistants - Launch Claude from explorer context menu with smart directory detection and project configuration",
  "version": "0.1.2",
  "publisher": "thinkube",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "claude",
    "ai",
    "thinkube",
    "code assistant"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmxela/thinkube-ai-integration"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "thinkube",
          "title": "Thinkube",
          "icon": "resources/tk_ai.svg"
        }
      ]
    },
    "views": {
      "thinkube": [
        {
          "id": "thinkubeBoards",
          "name": "Thinking Spaces",
          "contextualTitle": "Thinkube Thinking Spaces"
        },
        {
          "id": "thinkubeSpecs",
          "name": "Specs",
          "contextualTitle": "Thinkube Specs"
        },
        {
          "id": "claudeConfigTree",
          "name": "Configuration",
          "contextualTitle": "Claude Code Configuration"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "thinkubeSpecs",
        "contents": "Select a thinking space above to list its specs."
      }
    ],
    "commands": [
      {
        "command": "thinkube.boards.refresh",
        "title": "Refresh Boards",
        "category": "Thinkube Boards",
        "icon": "$(refresh)"
      },
      {
        "command": "thinkube.boards.open",
        "title": "Open Board",
        "category": "Thinkube Boards",
        "icon": "$(open-preview)"
      },
      {
        "command": "thinkube.boards.enable",
        "title": "Enable Methodology Here",
        "category": "Thinkube Boards",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.boards.migrate",
        "title": "Migrate Board to Sidecar",
        "category": "Thinkube Boards",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "thinkube.boards.showConfiguredOnly",
        "title": "Show Configured Thinking Spaces Only",
        "category": "Thinkube Boards",
        "icon": "$(filter)"
      },
      {
        "command": "thinkube.boards.showAll",
        "title": "Show All Repositories",
        "category": "Thinkube Boards",
        "icon": "$(filter-filled)"
      },
      {
        "command": "thinkube.boards.newClaudeSession",
        "title": "New Claude Session Here",
        "category": "Thinkube Boards",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "thinkube.boards.resumeClaudeSession",
        "title": "Resume Claude Session…",
        "category": "Thinkube Boards",
        "icon": "$(history)"
      },
      {
        "command": "thinkube-ai.claude.openHere",
        "title": "Open Here",
        "category": "Claude Code"
      },
      {
        "command": "thinkube.refreshConfig",
        "title": "Refresh Configuration",
        "category": "Thinkube AI",
        "icon": "$(refresh)"
      },
      {
        "command": "thinkube.addHook",
        "title": "Add Hook",
        "category": "Thinkube AI",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.deleteHook",
        "title": "Delete Hook",
        "category": "Thinkube AI",
        "icon": "$(trash)"
      },
      {
        "command": "thinkube.addCommand",
        "title": "Add Command",
        "category": "Thinkube AI",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.openCommand",
        "title": "Open Command",
        "category": "Thinkube AI"
      },
      {
        "command": "thinkube.deleteCommand",
        "title": "Delete Command",
        "category": "Thinkube AI",
        "icon": "$(trash)"
      },
      {
        "command": "thinkube.addSkill",
        "title": "Add Skill",
        "category": "Thinkube AI",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.openSkill",
        "title": "Open Skill",
        "category": "Thinkube AI"
      },
      {
        "command": "thinkube.deleteSkill",
        "title": "Delete Skill",
        "category": "Thinkube AI",
        "icon": "$(trash)"
      },
      {
        "command": "thinkube.addAgent",
        "title": "Add Agent",
        "category": "Thinkube AI",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.openAgent",
        "title": "Open Agent",
        "category": "Thinkube AI"
      },
      {
        "command": "thinkube.deleteAgent",
        "title": "Delete Agent",
        "category": "Thinkube AI",
        "icon": "$(trash)"
      },
      {
        "command": "thinkube.addMcpServer",
        "title": "Add MCP Server",
        "category": "Thinkube AI",
        "icon": "$(add)"
      },
      {
        "command": "thinkube.deleteMcpServer",
        "title": "Remove MCP Server",
        "category": "Thinkube AI",
        "icon": "$(trash)"
      },
      {
        "command": "thinkube.editPermissions",
        "title": "Edit Permissions",
        "category": "Thinkube AI",
        "icon": "$(edit)"
      },
      {
        "command": "thinkube.initializeConfig",
        "title": "Initialize Claude Config",
        "category": "Thinkube AI",
        "icon": "$(new-folder)"
      },
      {
        "command": "thinkube.switchProject",
        "title": "Set Active Project",
        "category": "Thinkube AI",
        "icon": "$(folder)"
      },
      {
        "command": "thinkube.kanban.openKanban",
        "title": "Open Kanban",
        "category": "Thinkube Kanban",
        "icon": "$(layout-panel)"
      },
      {
        "command": "thinkube.kanban.refreshFromGitHub",
        "title": "Refresh from GitHub",
        "category": "Thinkube Kanban",
        "icon": "$(sync)"
      },
      {
        "command": "thinkube.kanban.installBundle",
        "title": "Install Methodology Bundle",
        "category": "Thinkube Kanban",
        "icon": "$(package)"
      },
      {
        "command": "thinkube.kanban.statusBundle",
        "title": "Methodology Bundle Status",
        "category": "Thinkube Kanban",
        "icon": "$(info)"
      },
      {
        "command": "thinkube.kanban.diffBundle",
        "title": "Methodology Bundle Diff",
        "category": "Thinkube Kanban",
        "icon": "$(diff)"
      },
      {
        "command": "thinkube.specs.refresh",
        "title": "Refresh Specs",
        "category": "Thinkube Specs",
        "icon": "$(refresh)"
      },
      {
        "command": "thinkube.specs.startWorktree",
        "title": "Start Spec in Worktree",
        "category": "Thinkube Specs",
        "icon": "$(repo-clone)"
      },
      {
        "command": "thinkube.specs.retireWorktree",
        "title": "Retire Spec Worktree",
        "category": "Thinkube Specs",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "thinkube.boards.refresh",
          "when": "view == thinkubeBoards",
          "group": "navigation@0"
        },
        {
          "command": "thinkube.boards.showConfiguredOnly",
          "when": "view == thinkubeBoards && !thinkube.boards.configuredOnly",
          "group": "navigation@1"
        },
        {
          "command": "thinkube.boards.showAll",
          "when": "view == thinkubeBoards && thinkube.boards.configuredOnly",
          "group": "navigation@1"
        },
        {
          "command": "thinkube.refreshConfig",
          "when": "view == claudeConfigTree",
          "group": "navigation@0"
        },
        {
          "command": "thinkube.switchProject",
          "when": "view == claudeConfigTree",
          "group": "navigation@1"
        },
        {
          "command": "thinkube.specs.refresh",
          "when": "view == thinkubeSpecs",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "thinkube.specs.startWorktree",
          "when": "view == thinkubeSpecs && viewItem == spec-open",
          "group": "inline@0"
        },
        {
          "command": "thinkube.specs.retireWorktree",
          "when": "view == thinkubeSpecs && viewItem =~ /^spec-/",
          "group": "inline@1"
        },
        {
          "command": "thinkube.boards.enable",
          "when": "view == thinkubeBoards && viewItem == tandemBoardDisabled",
          "group": "inline"
        },
        {
          "command": "thinkube.boards.open",
          "when": "view == thinkubeBoards && viewItem == tandemBoardEnabled",
          "group": "inline"
        },
        {
          "command": "thinkube.boards.migrate",
          "when": "view == thinkubeBoards && viewItem =~ /tandemBoard/",
          "group": "9_migration"
        },
        {
          "command": "thinkube.boards.newClaudeSession",
          "when": "view == thinkubeBoards && viewItem =~ /tandemBoard/",
          "group": "inline@8"
        },
        {
          "command": "thinkube.boards.resumeClaudeSession",
          "when": "view == thinkubeBoards && viewItem =~ /tandemBoard/",
          "group": "inline@9"
        },
        {
          "command": "thinkube.kanban.installBundle",
          "when": "view == thinkubeBoards && viewItem =~ /tandemBundle/",
          "group": "inline@1"
        },
        {
          "command": "thinkube.kanban.diffBundle",
          "when": "view == thinkubeBoards && viewItem =~ /tandemBundle/",
          "group": "inline@2"
        },
        {
          "command": "thinkube.addHook",
          "when": "view == claudeConfigTree && viewItem == hooks-section",
          "group": "inline@1"
        },
        {
          "command": "thinkube.deleteHook",
          "when": "view == claudeConfigTree && viewItem == hook",
          "group": "inline"
        },
        {
          "command": "thinkube.addCommand",
          "when": "view == claudeConfigTree && viewItem == commands-section",
          "group": "inline@1"
        },
        {
          "command": "thinkube.deleteCommand",
          "when": "view == claudeConfigTree && viewItem == command",
          "group": "inline"
        },
        {
          "command": "thinkube.addSkill",
          "when": "view == claudeConfigTree && viewItem == skills-section",
          "group": "inline@1"
        },
        {
          "command": "thinkube.deleteSkill",
          "when": "view == claudeConfigTree && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "thinkube.addAgent",
          "when": "view == claudeConfigTree && viewItem == agents-section",
          "group": "inline@1"
        },
        {
          "command": "thinkube.deleteAgent",
          "when": "view == claudeConfigTree && viewItem == agent",
          "group": "inline"
        },
        {
          "command": "thinkube.addMcpServer",
          "when": "view == claudeConfigTree && viewItem == mcp-section",
          "group": "inline@1"
        },
        {
          "command": "thinkube.deleteMcpServer",
          "when": "view == claudeConfigTree && viewItem == mcp-server",
          "group": "inline"
        },
        {
          "command": "thinkube.editPermissions",
          "when": "view == claudeConfigTree && viewItem == permissions-section",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "submenu": "claude.code.submenu",
          "group": "navigation@30",
          "when": "explorerResourceIsFolder"
        }
      ],
      "claude.code.submenu": [
        {
          "command": "thinkube-ai.claude.openHere",
          "group": "1_session@1"
        }
      ],
      "commandPalette": [
        {
          "command": "thinkube-ai.claude.openHere",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "thinkube.kanban.openKanban"
        },
        {
          "command": "thinkube.kanban.refreshFromGitHub"
        }
      ]
    },
    "submenus": [
      {
        "id": "claude.code.submenu",
        "label": "Claude Code"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "thinkube.kanban",
        "label": "Thinkube Kanban"
      }
    ],
    "configuration": {
      "title": "Thinkube Kanban",
      "properties": {
        "thinkube.kanban.allowAIWrites": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Thinkube Kanban MCP server's mutating tools (move_slice, update_slice, write_decision, …). Set to false for navigator mode — AI can read and propose but cannot write. Overridden to false by `thinkube.kanban.mode = navigator`."
        },
        "thinkube.kanban.mode": {
          "type": "string",
          "enum": [
            "navigator",
            "driver",
            "both"
          ],
          "default": "both",
          "description": "Pair-programming role assignment. `navigator`: AI reads and proposes only (writes are blocked). `driver`: AI can write (typical when AI is leading implementation). `both`: either party can write at will (default)."
        },
        "thinkube.worktree.baseDir": {
          "type": "string",
          "default": "",
          "description": "Base directory for per-Spec git worktrees created by \"Start Spec in Worktree\". Empty = a sibling `<repo>-worktrees/` directory next to the repo. Keep it outside the repo tree so board discovery doesn't list worktrees as nested boards."
        },
        "thinkube.boards.root": {
          "type": "string",
          "default": "",
          "description": "Central board root (ADR-0008 / SP-8): the directory holding every Thinking Space's board, namespaced by `<container>/<rel>` (e.g. `Platform/extensions/thinkube-ai-integration`). Empty = legacy co-located `.thinkube/` in each repo. In thinkube this is the cloned sidecar board repo at `/home/thinkube/<board-repo>`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node scripts/build-assets.mjs && npm run compile:webview",
    "compile:webview": "npm --prefix webview/kanban run build",
    "install:webview": "npm --prefix webview/kanban install",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "tsc -p tsconfig.test.json && node --test out-test/",
    "test:vscode": "node ./dist/test/runTest.js",
    "publish:ovsx": "ovsx publish",
    "prepublish:ovsx": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^2.22.0",
    "ovsx": "^0.8.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^19.0.13",
    "yaml": "^2.9.0"
  }
}
